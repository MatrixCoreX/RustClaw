#!/usr/bin/env bash
set -euo pipefail

resolve_self_path() {
  local src="${BASH_SOURCE[0]}"
  while [[ -h "$src" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  local dir
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  echo "$dir/$(basename "$src")"
}

SELF_PATH="$(resolve_self_path)"
ROOT_DIR="$(cd "$(dirname "$SELF_PATH")" && pwd)"

START_SCRIPT="$ROOT_DIR/start-all.sh"
STOP_SCRIPT="$ROOT_DIR/stop-rustclaw.sh"
BUILD_SCRIPT="$ROOT_DIR/build-all.sh"


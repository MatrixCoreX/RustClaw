{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rustclaw.local/prompts/schemas/voice_mode_intent.schema.json",
  "title": "VoiceModeIntentOut",
  "description": "Structured output for Telegram voice/text reply mode intent detection.",
  "type": "object",
  "additionalProperties": false,
  "required": ["mode", "confidence", "reason"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["voice", "text", "both", "reset", "show", "none"],
      "description": "Explicit reply-mode switch intent label."
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Classifier confidence score."
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "description": "Short concrete explanation of the detected label."
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rustclaw.local/prompts/schemas/contract_repair_judge.schema.json",
  "title": "ContractRepairJudgeOut",
  "description": "Schema for the JSON object returned by prompts/contract_repair_judge_prompt.md. Mirrors ContractRepairJudgeOut in crates/clawd/src/intent_router.rs. The judge repairs malformed schema fields and machine contract fields; ordinary planner-loop semantic action choice remains outside this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apply",
    "reason",
    "confidence",
    "decision",
    "needs_clarify",
    "clarify_question",
    "resolved_user_intent",
    "output_contract",
    "execution_recipe",
    "turn_type",
    "target_task_policy"
  ],
  "properties": {
    "apply": {
      "type": "boolean",
      "description": "True only when malformed schema or machine contract fields should be repaired. False keeps the original conservative route."
    },
    "reason": {
      "type": "string"
    },
    "repair_target": {
      "type": "string",
      "description": "Optional canonical machine semantic target for the repair, such as directory_purpose_summary. Empty when no repair target is needed."
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "decision": {
      "type": "string",
      "enum": ["clarify", "direct_answer", "planner_execute"]
    },
    "needs_clarify": {
      "type": "boolean"
    },
    "clarify_question": {
      "type": "string"
    },
    "resolved_user_intent": {
      "type": "string"
    },
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "response_shape",
        "requires_content_evidence",
        "delivery_required",
        "locator_kind",
        "delivery_intent",
        "contract_marker",
        "locator_hint",
        "self_extension"
      ],
      "properties": {
        "response_shape": {
          "type": "string",
          "enum": ["free", "one_sentence", "strict", "scalar", "file_token"]
        },
        "exact_sentence_count": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "requires_content_evidence": {
          "type": "boolean"
        },
        "delivery_required": {
          "type": "boolean"
        },
        "locator_kind": {
          "type": "string",
          "enum": ["none", "path", "current_workspace", "url", "filename"]
        },
        "delivery_intent": {
          "type": "string",
          "enum": ["none", "file_single", "directory_lookup", "directory_batch_files"]
        },
        "contract_marker": {
          "type": "string",
          "description": "Preferred machine output-contract marker. Accepts the same stable marker tokens as legacy semantic_kind.",
          "enum": [
            "none",
            "raw_command_output",
            "command_output_summary",
            "service_status",
            "hidden_entries_check",
            "file_names",
            "directory_names",
            "directory_entry_groups",
            "file_paths",
            "directory_purpose_summary",
            "content_excerpt_summary",
            "document_heading",
            "content_excerpt_with_summary",
            "content_presence_check",
            "excerpt_kind_judgment",
            "recent_artifacts_judgment",
            "workspace_project_summary",
            "scalar_count",
            "quantity_comparison",
            "execution_failed_step",
            "generated_file_delivery",
            "generated_file_path_report",
            "filesystem_mutation_result",
            "scalar_path_only",
            "file_basename",
            "existence_with_path",
            "existence_with_path_summary",
            "recent_scalar_equality_check",
            "structured_keys"
          ]
        },
        "semantic_kind": {
          "type": "string",
          "description": "Legacy compatibility input. New repair judge prompts should emit contract_marker.",
          "enum": [
            "none",
            "raw_command_output",
            "command_output_summary",
            "service_status",
            "hidden_entries_check",
            "file_names",
            "directory_names",
            "directory_entry_groups",
            "file_paths",
            "directory_purpose_summary",
            "content_excerpt_summary",
            "document_heading",
            "content_excerpt_with_summary",
            "content_presence_check",
            "excerpt_kind_judgment",
            "recent_artifacts_judgment",
            "workspace_project_summary",
            "scalar_count",
            "quantity_comparison",
            "execution_failed_step",
            "generated_file_delivery",
            "generated_file_path_report",
            "filesystem_mutation_result",
            "scalar_path_only",
            "file_basename",
            "existence_with_path",
            "existence_with_path_summary",
            "recent_scalar_equality_check",
            "structured_keys"
          ]
        },
        "locator_hint": {
          "type": "string"
        },
        "scalar_count_filter": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "target_kind": {
              "type": "string",
              "enum": ["any", "file", "dir", ""]
            },
            "include_hidden": {
              "type": ["boolean", "null"]
            },
            "recursive": {
              "type": ["boolean", "null"]
            }
          }
        },
        "list_selector": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "target_kind": {
              "type": "string",
              "enum": ["any", "file", "dir", ""]
            },
            "limit": {
              "type": ["integer", "string", "null"]
            },
            "sort_by": {
              "type": "string",
              "enum": ["name", "name_desc", "size_desc", "size_asc", "mtime_desc", "mtime_asc", ""]
            },
            "include_metadata": {
              "type": ["boolean", "null"]
            }
          }
        },
        "self_extension": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "trigger", "execute_now"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["none", "temporary_fix", "permanent_extension"]
            },
            "trigger": {
              "type": "string",
              "enum": ["none", "explicit_user_request", "capability_gap"]
            },
            "execute_now": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "execution_recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "profile", "target_scope"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["none", "ops_closed_loop"]
        },
        "profile": {
          "type": "string",
          "enum": [
            "none",
            "ops_service",
            "config_change",
            "code_change",
            "problem_resolution",
            "skill_authoring",
            "extension_build",
            "package_change",
            "dependency_change",
            "database_change",
            "schema_change"
          ]
        },
        "target_scope": {
          "type": "string",
          "enum": [
            "unknown",
            "system",
            "current_repo",
            "external_workspace",
            "greenfield"
          ]
        }
      }
    },
    "turn_type": {
      "type": "string",
      "enum": [
        "",
        "task_request",
        "task_append",
        "task_replace",
        "task_correct",
        "task_scope_update",
        "run_control",
        "approval_decision",
        "status_query",
        "feedback_or_error",
        "preference_or_memory"
      ]
    },
    "target_task_policy": {
      "type": "string",
      "enum": ["", "reuse_active", "replace_active", "pause_and_queue", "standalone"]
    },
    "state_patch": {
      "type": ["object", "null"],
      "description": "Optional structured runtime/session patch to preserve when repairing malformed normalizer output. May include ordered_entry_ref ({\"index\":N,\"index_base\":1} or {\"relative_offset\":K}) for active ordered-entry selection. For active-task corrections, may include required_content_literals, forbidden_visible_literals, and replacement_pairs [{\"from\":\"old literal\",\"to\":\"new literal\"}] as exact current-turn content literals; output-control wording belongs in the intent/output contract, not required_content_literals."
    }
  }
}

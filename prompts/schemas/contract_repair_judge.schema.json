{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rustclaw.local/prompts/schemas/contract_repair_judge.schema.json",
  "title": "ContractRepairJudgeOut",
  "description": "Schema for the JSON object returned by prompts/contract_repair_judge_prompt.md. Mirrors ContractRepairJudgeOut in crates/clawd/src/intent_router.rs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apply",
    "reason",
    "confidence",
    "decision",
    "needs_clarify",
    "clarify_question",
    "resolved_user_intent",
    "output_contract",
    "execution_recipe",
    "turn_type",
    "target_task_policy"
  ],
  "properties": {
    "apply": {
      "type": "boolean",
      "description": "True only when the malformed fields should be repaired semantically. False keeps the original conservative route."
    },
    "reason": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "decision": {
      "type": "string",
      "enum": ["clarify", "direct_answer", "planner_execute"]
    },
    "needs_clarify": {
      "type": "boolean"
    },
    "clarify_question": {
      "type": "string"
    },
    "resolved_user_intent": {
      "type": "string"
    },
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "response_shape",
        "requires_content_evidence",
        "delivery_required",
        "locator_kind",
        "delivery_intent",
        "semantic_kind",
        "locator_hint",
        "self_extension"
      ],
      "properties": {
        "response_shape": {
          "type": "string",
          "enum": ["free", "one_sentence", "strict", "scalar", "file_token"]
        },
        "exact_sentence_count": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "requires_content_evidence": {
          "type": "boolean"
        },
        "delivery_required": {
          "type": "boolean"
        },
        "locator_kind": {
          "type": "string",
          "enum": ["none", "path", "current_workspace", "url", "filename"]
        },
        "delivery_intent": {
          "type": "string",
          "enum": ["none", "file_single", "directory_lookup", "directory_batch_files"]
        },
        "semantic_kind": {
          "type": "string",
          "enum": [
            "none",
            "raw_command_output",
            "service_status",
            "hidden_entries_check",
            "file_names",
            "directory_names",
            "directory_entry_groups",
            "file_paths",
            "directory_purpose_summary",
            "content_excerpt_summary",
            "content_presence_check",
            "excerpt_kind_judgment",
            "recent_artifacts_judgment",
            "workspace_project_summary",
            "scalar_count",
            "quantity_comparison",
            "execution_failed_step",
            "generated_file_delivery",
            "scalar_path_only",
            "existence_with_path",
            "existence_with_path_summary",
            "recent_scalar_equality_check",
            "git_commit_subject",
            "structured_keys",
            "sqlite_table_listing",
            "sqlite_table_names_only",
            "sqlite_database_kind_judgment",
            "sqlite_schema_version",
            "archive_list",
            "archive_pack",
            "archive_unpack",
            "docker_ps",
            "docker_images",
            "docker_logs",
            "docker_container_lifecycle"
          ]
        },
        "locator_hint": {
          "type": "string"
        },
        "self_extension": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "trigger", "execute_now"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["none", "temporary_fix", "permanent_extension"]
            },
            "trigger": {
              "type": "string",
              "enum": ["none", "explicit_user_request", "capability_gap"]
            },
            "execute_now": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "execution_recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "profile", "target_scope"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["none", "ops_closed_loop"]
        },
        "profile": {
          "type": "string",
          "enum": [
            "none",
            "ops_service",
            "config_change",
            "code_change",
            "problem_resolution",
            "skill_authoring",
            "extension_build"
          ]
        },
        "target_scope": {
          "type": "string",
          "enum": [
            "unknown",
            "system",
            "current_repo",
            "external_workspace",
            "greenfield"
          ]
        }
      }
    },
    "turn_type": {
      "type": "string",
      "enum": [
        "",
        "task_request",
        "task_append",
        "task_replace",
        "task_correct",
        "task_scope_update",
        "run_control",
        "approval_decision",
        "status_query",
        "feedback_or_error",
        "preference_or_memory"
      ]
    },
    "target_task_policy": {
      "type": "string",
      "enum": ["", "reuse_active", "replace_active", "pause_and_queue", "standalone"]
    }
  }
}

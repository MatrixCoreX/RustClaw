{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rustclaw.local/prompts/schemas/direct_answer_gate.schema.json",
  "title": "DirectAnswerGateOut",
  "description": "Schema for the JSON object returned by prompts/direct_answer_gate_prompt.md. This output is a fallback safety decision for legacy direct-answer paths, not the ordinary semantic authority when planner-loop routing is enabled.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision",
    "reason",
    "confidence",
    "clarify_question",
    "resolved_user_intent",
    "reference_resolution",
    "output_contract"
  ],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["direct_answer", "planner_execute", "clarify"]
    },
    "reason": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "clarify_question": {
      "type": "string"
    },
    "resolved_user_intent": {
      "type": "string"
    },
    "reference_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target"],
      "properties": {
        "target": {
          "type": "string",
          "enum": [
            "none",
            "current_action_result",
            "current_turn_locator",
            "comparison_result",
            "unresolved_prior_object",
            "missing_locator",
            "ambiguous_locator"
          ]
        }
      }
    },
    "state_patch": {
      "description": "Optional structured state patch for already-observed direct-answer follow-ups, such as quantity_comparison={source,selection,candidates,winner}. Runtime consumes this as machine state, not user-visible prose.",
      "type": ["object", "null"],
      "default": null
    },
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "response_shape",
        "requires_content_evidence",
        "delivery_required",
        "locator_kind",
        "delivery_intent",
        "semantic_kind",
        "locator_hint",
        "self_extension"
      ],
      "properties": {
        "response_shape": {
          "type": "string",
          "enum": ["free", "one_sentence", "strict", "scalar", "file_token"]
        },
        "exact_sentence_count": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "requires_content_evidence": {
          "type": "boolean"
        },
        "delivery_required": {
          "type": "boolean"
        },
        "locator_kind": {
          "type": "string",
          "enum": ["none", "path", "current_workspace", "url", "filename"]
        },
        "delivery_intent": {
          "type": "string",
          "enum": ["none", "file_single", "directory_lookup", "directory_batch_files"]
        },
        "semantic_kind": {
          "type": "string",
          "enum": [
            "none",
            "raw_command_output",
            "command_output_summary",
            "service_status",
            "hidden_entries_check",
            "file_names",
            "directory_names",
            "directory_entry_groups",
            "file_paths",
            "directory_purpose_summary",
            "content_excerpt_summary",
            "document_heading",
            "content_excerpt_with_summary",
            "content_presence_check",
            "excerpt_kind_judgment",
            "recent_artifacts_judgment",
            "workspace_project_summary",
            "scalar_count",
            "quantity_comparison",
            "execution_failed_step",
            "generated_file_delivery",
            "generated_file_path_report",
            "filesystem_mutation_result",
            "scalar_path_only",
            "file_basename",
            "existence_with_path",
            "existence_with_path_summary",
            "recent_scalar_equality_check",
            "git_commit_subject",
            "git_repository_state",
            "structured_keys",
            "config_validation",
            "config_mutation",
            "config_risk_assessment",
            "rss_news_fetch",
            "web_page_summary",
            "web_search_summary",
            "weather_query",
            "market_quote",
            "image_understanding",
            "publishing_preview",
            "package_manager_detection",
            "sqlite_table_listing",
            "sqlite_table_names_only",
            "sqlite_database_kind_judgment",
            "sqlite_schema_version",
            "archive_list",
            "archive_read",
            "archive_pack",
            "archive_unpack",
            "docker_ps",
            "docker_images",
            "docker_logs",
            "docker_container_lifecycle"
          ]
        },
        "locator_hint": {
          "type": "string"
        },
        "self_extension": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "trigger", "execute_now"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["none", "temporary_fix", "permanent_extension"]
            },
            "trigger": {
              "type": "string",
              "enum": ["none", "explicit_user_request", "capability_gap"]
            },
            "execute_now": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
